{
  "version": 2,
  "outputDirectory": "web",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    {
      "src": "/fetch",
      "dest": "/api/index.js"
    },
    {
      "src": "/providers",
      "dest": "/api/index.js"
    },
    {
      "src": "/status",
      "dest": "/api/index.js"
    },
    {
      "src": "/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/vlc",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
